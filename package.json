{
  "name": "gulf-premium-telecom",
  "version": "1.0.0",
  "description": "Asterisk-based inbound SIP call receiver with IVR and real-time dashboard",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "test": "jest"
  },
  "keywords": [
    "asterisk",
    "sip",
    "ivr",
    "telecom",
    "voip"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "asterisk-manager": "^0.1.16",
    "ws": "^8.14.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "mongodb": "^6.2.0",
    "mongoose": "^8.0.0",
    "uuid": "^9.0.1",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0"
  }
}
