# Gulf Premium Telecom Environment Variables

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/gulf_premium_telecom?schema=public"
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gulf_premium_telecom
DB_USER=asterisk_api
DB_PASSWORD=your_secure_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API
PORT=3001
NODE_ENV=development
API_BASE_URL=http://localhost:3001

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# NextAuth (Frontend)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_change_this_in_production

# AGI Server
AGI_PORT=4573
AGI_HOST=0.0.0.0

# Asterisk
ASTERISK_AMI_HOST=localhost
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=admin
ASTERISK_AMI_SECRET=your_ami_password

# Monitoring
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/gulf-premium-telecom

# Recording
RECORDING_PATH=/var/spool/asterisk/monitor
RECORDING_BASE_URL=https://recordings.example.com

# SMTP (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@gulfpremium.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=Gulf Premium Telecom <noreply@gulfpremium.com>

# External Services
TIMEZONE=Asia/Riyadh
DEFAULT_COUNTRY_CODE=+966

# Feature Flags
ENABLE_CALL_RECORDING=true
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true
