// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AllocationNumber {
  id               String   @id @default(uuid())
  allocatedNumber  String   @unique @map("allocated_number")
  destinationId    String?  @map("destination_id")
  customerId       String?  @map("customer_id")
  status           String   @default("active")
  allocatedAt      DateTime @default(now()) @map("allocated_at")
  expiresAt        DateTime? @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  destination      InboundDestination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  customer         Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  
  @@index([allocatedNumber])
  @@index([destinationId])
  @@index([customerId])
  @@index([status])
  @@map("allocation_numbers")
}

model InboundDestination {
  id                String   @id @default(uuid())
  destinationNumber String   @map("destination_number")
  destinationName   String?  @map("destination_name")
  routingType       String   @map("routing_type")
  countryCode       String?  @map("country_code")
  areaCode          String?  @map("area_code")
  trunkId           String?  @map("trunk_id")
  status            String   @default("active")
  maxChannels       Int      @default(10) @map("max_channels")
  currentChannels   Int      @default(0) @map("current_channels")
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  allocations       AllocationNumber[]
  routingRules      RoutingRule[]
  trunk             SipTrunk?          @relation(fields: [trunkId], references: [id], onDelete: SetNull)
  callRecords       CallDetailRecord[]
  
  @@index([destinationNumber])
  @@index([status])
  @@index([trunkId])
  @@map("inbound_destinations")
}

model RoutingRule {
  id             String   @id @default(uuid())
  destinationId  String   @map("destination_id")
  priority       Int      @default(10)
  action         String
  actionData     Json     @map("action_data")
  conditions     Json?
  timeBased      Boolean  @default(false) @map("time_based")
  schedule       Json?
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  
  destination    InboundDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  
  @@index([destinationId, priority])
  @@index([status])
  @@map("routing_rules")
}

model Customer {
  id              String   @id @default(uuid())
  companyName     String   @map("company_name")
  contactName     String?  @map("contact_name")
  email           String   @unique
  phone           String?
  country         String?
  billingCycle    String   @default("monthly") @map("billing_cycle")
  creditLimit     Decimal  @default(0.00) @map("credit_limit") @db.Decimal(10, 2)
  currentBalance  Decimal  @default(0.00) @map("current_balance") @db.Decimal(10, 2)
  status          String   @default("active")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  allocations     AllocationNumber[]
  callRecords     CallDetailRecord[]
  rateCards       RateCard[]
  users           User[]
  
  @@index([email])
  @@index([status])
  @@map("customers")
}

model SipTrunk {
  id             String   @id @default(uuid())
  trunkName      String   @unique @map("trunk_name")
  providerName   String?  @map("provider_name")
  sipServer      String   @map("sip_server")
  sipPort        Int      @default(5060) @map("sip_port")
  protocol       String   @default("UDP")
  authType       String   @default("IP") @map("auth_type")
  allowedIps     String[] @map("allowed_ips")
  codecPriority  String[] @default(["ulaw", "alaw", "g729"]) @map("codec_priority")
  maxChannels    Int      @default(100) @map("max_channels")
  cpsLimit       Int      @default(10) @map("cps_limit")
  status         String   @default("active")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  
  destinations   InboundDestination[]
  callRecords    CallDetailRecord[]
  
  @@index([trunkName])
  @@index([status])
  @@map("sip_trunks")
}

model CallDetailRecord {
  id                 String    @id @default(uuid())
  uniqueid           String    @unique
  linkedid           String?
  allocatedNumber    String?   @map("allocated_number")
  destinationNumber  String?   @map("destination_number")
  callerId           String?   @map("caller_id")
  callerName         String?   @map("caller_name")
  startTime          DateTime  @map("start_time")
  answerTime         DateTime? @map("answer_time")
  endTime            DateTime? @map("end_time")
  duration           Int       @default(0)
  billsec            Int       @default(0)
  disposition        String?
  hangupCause        String?   @map("hangup_cause")
  trunkId            String?   @map("trunk_id")
  customerId         String?   @map("customer_id")
  destinationId      String?   @map("destination_id")
  recordingFile      String?   @map("recording_file")
  costPerMinute      Decimal?  @map("cost_per_minute") @db.Decimal(10, 4)
  totalCost          Decimal?  @map("total_cost") @db.Decimal(10, 2)
  metadata           Json?
  createdAt          DateTime  @default(now()) @map("created_at")
  
  trunk              SipTrunk?           @relation(fields: [trunkId], references: [id], onDelete: SetNull)
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  destination        InboundDestination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  
  @@index([uniqueid])
  @@index([allocatedNumber])
  @@index([startTime])
  @@index([customerId])
  @@index([disposition])
  @@index([trunkId])
  @@map("call_detail_records")
}

model RateCard {
  id                 String    @id @default(uuid())
  rateName           String    @map("rate_name")
  destinationPrefix  String    @map("destination_prefix")
  destinationName    String?   @map("destination_name")
  ratePerMinute      Decimal   @map("rate_per_minute") @db.Decimal(10, 4)
  connectionFee      Decimal   @default(0.0000) @map("connection_fee") @db.Decimal(10, 4)
  billingIncrement   Int       @default(60) @map("billing_increment")
  minDuration        Int       @default(0) @map("min_duration")
  effectiveDate      DateTime  @map("effective_date") @db.Date
  expiryDate         DateTime? @map("expiry_date") @db.Date
  customerId         String?   @map("customer_id")
  status             String    @default("active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  
  customer           Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  @@index([destinationPrefix])
  @@index([customerId])
  @@index([effectiveDate, expiryDate])
  @@map("rate_cards")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String?
  hashedPassword String?  @map("hashed_password")
  role           String   @default("user")
  customerId     String?  @map("customer_id")
  status         String   @default("active")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  auditLogs      SystemAuditLog[]
  
  @@index([email])
  @@index([customerId])
  @@map("users")
}

model SystemAuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  action      String
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")
  
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("system_audit_logs")
}
